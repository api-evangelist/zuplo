{
  "name": "Zuplo API Key",
  "description": "Structure of a Zuplo API key resource",
  "fields": [
    { "name": "id", "type": "string", "required": true, "description": "Unique key identifier" },
    { "name": "key", "type": "string", "required": true, "description": "The API key value" },
    { "name": "consumerId", "type": "string", "required": true, "description": "Owning consumer ID" },
    { "name": "bucketName", "type": "string", "required": true, "description": "Owning bucket name" },
    { "name": "description", "type": "string", "required": false, "description": "Key description" },
    { "name": "tags", "type": "object", "required": false, "description": "Custom metadata tags" },
    { "name": "expiresOn", "type": "string (date-time)", "required": false, "description": "Key expiration" },
    { "name": "createdOn", "type": "string (date-time)", "required": false, "description": "Creation time" },
    { "name": "updatedOn", "type": "string (date-time)", "required": false, "description": "Last update time" }
  ]
}
